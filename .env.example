# Server
PORT=3000
NODE_ENV=production

# Pagination
PAGINATION_DEFAULT_PAGE=1
PAGINATION_DEFAULT_LIMIT=10

# JWT
SECRET_KEY=
TOKEN_EXPIRES_IN=8h
AUTH_DEBUG=false

# Email
EMAIL_USER=
EMAIL_PASS=
BUSINESS_EMAIL=
EMAIL_CODE_TTL_MINUTES=15

# Database
DATABASE_URL=
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASS=
DB_NAME=LGYM
DB_SYNC_ALTER=false
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=true

# User states and roles
USER_PENDING_STATE_ID=2
USER_ACTIVE_STATE_ID=1
DEFAULT_ROLE_ID=33
ADMIN_ROLE_ID=32
ADMIN_ROLE_NAME=Administrador
ADMIN_USER_ID=
PROTECTED_DELETE_ROLE_ID=32
PROTECTED_ROLE_IDS=32,33

# CORS
CORS_ORIGINS=*
CORS_ALLOW_CREDENTIALS=false
CORS_HEADERS=Origin, X-Requested-With, Content-Type, Accept, Authorization, ngrok-skip-browser-warning
CORS_METHODS=GET, POST, PUT, PATCH, DELETE, OPTIONS
CORS_EXPOSE_HEADERS=x-refreshed-token
CORS_MAX_AGE=86400
